# Myosotis web app configuration
# Copy to .env.local for local development.

# Path to the root of the config repository mounted into the container.
# In production this is set via docker-compose CONFIG_ROOT env var.
# CONFIG_ROOT=/app/repo

# Optional: show a branded footer link.
# Leave blank to show the default "Myosotis — open-source AI workspace" footer.
NEXT_PUBLIC_HOMEPAGE_URL=
NEXT_PUBLIC_HOMEPAGE_LABEL=
