# Shared Archon stack for Shiftbloom Studio.
# Render a real file as compose/.env.shared from AWS Secrets Manager.

DOMAIN=archon.shiftbloom.studio
PORT=3000
ARCHON_DATA=/opt/shiftbloom-archon/data
LOG_LEVEL=info
MAX_CONCURRENT_CONVERSATIONS=10

# Archon metadata database only.
DATABASE_URL=postgresql://archon:REPLACE_ME@shiftbloom-archon-db.cluster-xxxx.eu-central-1.rds.amazonaws.com:5432/archon

# Caddy basic auth fragment produced via:
# docker run --rm caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
# Example:
# CADDY_BASIC_AUTH=basicauth @protected { admin $$2a$$14$$REPLACE_WITH_HASH }
CADDY_BASIC_AUTH=

# Shared stack AI credentials.
DEFAULT_AI_ASSISTANT=claude
CLAUDE_USE_GLOBAL_AUTH=false
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_API_KEY=
CODEX_ID_TOKEN=
CODEX_ACCESS_TOKEN=
CODEX_REFRESH_TOKEN=
CODEX_ACCOUNT_ID=

# Shared integration credentials.
GH_TOKEN=
GITHUB_TOKEN=

