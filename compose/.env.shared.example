# Shared Archon stack for Shiftbloom Studio.
# Render a real file as compose/.env.shared from AWS Secrets Manager.

# Preferred final hostname:
DOMAIN=archon.shiftbloom.studio
# Temporary fallback until external DNS points to the EC2 host:
# DOMAIN=http://108.131.131.129
PORT=3000
ARCHON_DATA=/opt/shiftbloom-archon/data
LOG_LEVEL=info
MAX_CONCURRENT_CONVERSATIONS=10

# Archon metadata database only.
DATABASE_URL=postgresql://archon:REPLACE_ME@shiftbloom-archon-db.cluster-xxxx.eu-west-1.rds.amazonaws.com:5432/archon?sslmode=require&uselibpqcompat=true

# Caddy basic auth credentials.
# Generate hash via:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=

# Shared stack AI credentials.
DEFAULT_AI_ASSISTANT=claude
CLAUDE_USE_GLOBAL_AUTH=false
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_API_KEY=
CODEX_ID_TOKEN=
CODEX_ACCESS_TOKEN=
CODEX_REFRESH_TOKEN=
CODEX_ACCOUNT_ID=

# Shared integration credentials.
GH_TOKEN=
GITHUB_TOKEN=
