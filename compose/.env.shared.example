# Myosotis shared stack configuration.
# Copy to compose/.env.shared and fill in the values.

# Your public domain (Caddy provisions TLS automatically via Let's Encrypt).
DOMAIN=myosotis.example.com

# Email for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

PORT=3000

# Path to the git clone of your config repo inside the container.
CONFIG_REPO=/opt/myosotis/repo

# Caddy basic auth credentials.
# Generate hash via:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=
